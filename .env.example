# Copia este archivo como .env y rellena tus valores reales.
# El archivo .env NUNCA se sube al repositorio (está en .gitignore).
# Las claves son leídas directamente por el backend Rust; no se exponen al frontend.

# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Modelo Gemini a usar (opcional, por defecto: gemini-2.5-flash)
# Opciones: gemini-2.5-flash, gemini-2.5-pro, gemini-3-flash-preview
GEMINI_MODEL=gemini-2.5-flash

# Supabase (Settings → API en tu proyecto Supabase)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=
