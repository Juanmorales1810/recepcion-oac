{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Recepcion OAC",
    "version": "0.1.0",
    "identifier": "com.juanmorales.recepcion-oac",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "splashscreen",
                "title": "Recepcion OAC",
                "url": "splashscreen.html",
                "width": 480,
                "height": 360,
                "center": true,
                "resizable": false,
                "decorations": false,
                "visible": false,
                "alwaysOnTop": true,
                "skipTaskbar": true
            },
            {
                "label": "main",
                "title": "Recepcion OAC",
                "width": 1200,
                "height": 800,
                "minWidth": 900,
                "minHeight": 600,
                "center": true,
                "visible": false
            }
        ],
        "security": {
            "csp": null
        },
        "withGlobalTauri": true
    },
    "bundle": {
        "active": true,
        "targets": ["nsis", "msi"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": ["images/*", "../.env"],
        "publisher": "Juan Morales",
        "copyright": "© 2026 Juan Morales. Todos los derechos reservados.",
        "category": "Productivity",
        "shortDescription": "Sistema de recepción y gestión documental de la OAC",
        "longDescription": "Recepcion OAC es una aplicación de escritorio para la recepción, clasificación y seguimiento de documentos de la Oficina de Atención al Ciudadano. Permite procesar documentos PDF, extraer información con IA y gestionar el registro histórico.",
        "windows": {
            "webviewInstallMode": {
                "type": "embedBootstrapper"
            },
            "nsis": {
                "installerIcon": "icons/icon.ico",
                "headerImage": "images/nsis-header.bmp",
                "sidebarImage": "images/nsis-sidebar.bmp",
                "installMode": "currentUser",
                "displayLanguageSelector": true,
                "languages": ["Spanish", "English"],
                "startMenuFolder": "Recepcion OAC",
                "compression": "lzma"
            }
        }
    }
}
